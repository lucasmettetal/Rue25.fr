# PostgreSQL — Docker sur port 5433
DATABASE_URL=postgresql://rue25:rue25@127.0.0.1:5433/rue25

# JWT — clé secrète longue (min 32 caractères)
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Compte admin créé au seed
ADMIN_EMAIL=admin@rue25.fr
ADMIN_PASSWORD=admin25

# Serveur
PORT=3001
CLIENT_URL=http://localhost:5173

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email transactionnel (optionnel — désactivé si absent)
# Compatible Gmail (mot de passe d'application), SendGrid, Mailgun, Resend SMTP…
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=Rue 25 <votre@email.com>
